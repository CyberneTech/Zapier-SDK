# ── Demo mode ────────────────────────────────────────────────────────────────
# MOCK=true runs the whole pipeline locally with fake SDK + LLM (no accounts needed).
# Set MOCK=false once you've run `npx zapier-sdk login` and connected your apps.
MOCK=true

# GO_LIVE=false keeps the demo safe (drafts / scheduled). true actually publishes.
GO_LIVE=false

# ── LLM (model-flexible: OpenAI / Anthropic / Gemini / Kimi). Only needed if MOCK=false ──
OPENAI_API_KEY=sk-...

# ── Real-run config (only needed if MOCK=false) ──────────────────────────────
SHEET_ID=your-google-sheet-id
SLACK_CHANNEL=#launches
BUFFER_PROFILE_IDS=
NOTION_DB=
LIST_TEST_ADDR=you@example.com

# ── Headless/serverless auth (optional; from `npx zapier-sdk create-client-credentials`) ──
ZAPIER_CLIENT_ID=
ZAPIER_CLIENT_SECRET=
